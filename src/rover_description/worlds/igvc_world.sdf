</sdf>

    <!--
      Lane layout (all units in metres):
      
      Coordinate system: +X = right, +Y = up (in Gazebo top-down view)

      straight1 : travels +X, y_left=+0.6, y_right=-0.6,  x = 0..12
      corner1   : SE turn (+X → +Y), centre=(12, 1.8), r_inner=1.2, r_outer=2.4
      straight2 : travels +Y, x_left=13.2, x_right=14.4,  y = 1.8..13.8
      corner2   : NE turn (+Y → -X), centre=(12, 13.8),   r_inner=1.2, r_outer=2.4
      straight3 : travels -X, y_left=15.0, y_right=16.2,  x = 12..0
      corner3   : NW turn (-X → -Y), centre=(0,  13.8),   r_inner=1.2, r_outer=2.4
      straight4 : travels -Y, x_left=-1.2, x_right=-2.4,  y = 13.8..1.8
      corner4   : SW turn (-Y → +X), centre=(0,  1.8),    r_inner=1.2, r_outer=2.4
      (closes back to straight1 start)

      Each curved corner is approximated by 8 box segments per wall
      (45-degree arc segments give smooth-looking 90° turns).
      Segment poses are computed at angles: 0°, 11.25°, 22.5°, 33.75°,
      45°, 56.25°, 67.5°, 78.75°  (centres of each 11.25° slice).
      Box size along arc ≈ r * sin(11.25°/2)*2 * 2 ≈ r * 0.196 (chord length),
      width = 0.06 m (line thickness), height = 0.01 m (flat on ground).

      White material: ambient/diffuse = 1 1 1 1
    -->

    <model name="lane_system"><static>true</static><pose>0 0 0.005 0 0 0</pose>

      <!-- ═══════════════════════════════════════════════════
           STRAIGHT 1  (+X direction, y = ±0.6, x = 0 → 12)
           ═══════════════════════════════════════════════════ -->
      <link name="straight1">
        <!-- left wall  (y = +0.6) -->
        <visual name="l"><pose>6 0.6 0 0 0 0</pose>
          <geometry><box><size>12.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <!-- right wall (y = -0.6) -->
        <visual name="r"><pose>6 -0.6 0 0 0 0</pose>
          <geometry><box><size>12.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
      </link>

      <!-- ═══════════════════════════════════════════════════
           CORNER 1  (+X → +Y)   centre = (12, 1.8)
           Inner wall r=1.2  (left lane wall)
           Outer wall r=2.4  (right lane wall)
           Sweep: 270° → 360° (i.e. from -Y axis toward +X axis)
           Segment centre angles from +X axis: 270+k*11.25 for k=0..7
           In standard math: angles -90°..-0° (equivalently 270°..360°)
           ═══════════════════════════════════════════════════ -->

      <!-- Inner arc (r=1.2): segment centres at angle θ from +X, 
           world pos = centre + r*(cos θ, sin θ)
           box yaw = θ + 90° (tangent direction)
           θ values (deg): -84.375 -73.125 -61.875 -50.625 -39.375 -28.125 -16.875 -5.625
           = radians:       -1.473  -1.276  -1.080  -0.883  -0.687  -0.491  -0.294  -0.098
           r*sin(11.25°/2)*2 = chord ≈ 1.2*0.1960 = 0.235 → use 0.24 for slight overlap
      -->
