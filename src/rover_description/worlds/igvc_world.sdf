<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="tight_lane_world">
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light name="sun" type="directional">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.85 1</diffuse>
      <specular>0 0 0 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="col">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="vis">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!--
      Rectangular lane loop
      ─────────────────────
      Corner pivot centres:  SW=(1.5,1.5)  SE=(10.5,1.5)  NE=(10.5,10.5)  NW=(1.5,10.5)
      Inner arc radius : 1.5 m
      Lane width       : 1.2 m  →  outer arc radius = 2.7 m
      Straights (length 9 m each):
        Bottom  y_inner= 0.0  y_outer=-1.2   x: 1.5→10.5
        Right   x_inner=12.0  x_outer=13.2   y: 1.5→10.5
        Top     y_inner=12.0  y_outer=13.2   x: 10.5→1.5
        Left    x_inner= 0.0  x_outer=-1.2   y: 10.5→1.5
      Each corner = 8 segments × 11.25° = exactly 90°
      Segment chord: inner=0.2941 m, outer=0.5293 m
    -->

    <model name="lane_system">
      <static>true</static>
      <pose>0 0 0.005 0 0 0</pose>

      <!-- ═══════════════════════════ STRAIGHTS ═══════════════════════════ -->

      <link name="straight_bottom">
        <visual name="inner"><pose>6.0  0.0 0  0 0 0</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="outer"><pose>6.0 -1.2 0  0 0 0</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
      </link>

      <link name="straight_right">
        <visual name="inner"><pose>12.0 6.0 0  0 0 1.5708</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="outer"><pose>13.2 6.0 0  0 0 1.5708</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
      </link>

      <link name="straight_top">
        <visual name="inner"><pose>6.0 12.0 0  0 0 3.1416</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="outer"><pose>6.0 13.2 0  0 0 3.1416</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
      </link>

      <link name="straight_left">
        <visual name="inner"><pose> 0.0 6.0 0  0 0 4.7124</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="outer"><pose>-1.2 6.0 0  0 0 4.7124</pose>
          <geometry><box><size>9.0 0.06 0.01</size></box></geometry>
          <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
      </link>

      <!-- ═══════════════════════════ CORNER SW  (pivot 1.5, 1.5  |  sweep 180°→270°) ═══════════════════════════ -->

      <link name="c_SW_inner">
        <visual name="s0"><pose>0.0072 1.3530 0  0 0 4.8106</pose><geometry><box><size>0.2941 0.06 0.01</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
