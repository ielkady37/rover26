# =============================================================================
#  rover26 – environment configuration EXAMPLE
#  Copy this file to .env.local (dev) or .env.rasp (production) and fill in
#  the values.  Never commit .env.local or .env.rasp to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# ENV can be: REALTIME | DEV | TEST
# REALTIME disables non-critical fallbacks and enables strict fault handling.
# -----------------------------------------------------------------------------
ENV=DEV

# -----------------------------------------------------------------------------
# Redis
# Used by: RoverLogger (stream), IHealthCheckable (health hashes),
#          LoggerNode, HealthMonitorNode
# -----------------------------------------------------------------------------
ROVER_REDIS_HOST=localhost
ROVER_REDIS_PORT=6379
ROVER_REDIS_DB=0
# ROVER_REDIS_PASS=

# -----------------------------------------------------------------------------
# Logger (RoverLogger / LoggerNode)
# ROVER_LOG_STREAM_KEY   – Redis stream name for log entries
# ROVER_LOG_STREAM_MAX   – max entries kept before Redis trims the stream
# ROVER_LOGGER_DRAIN_HZ  – how often LoggerNode reads from the stream (Hz)
# ROVER_LOGGER_BLOCK_MS  – XREAD blocking timeout per call (ms)
# ROVER_LOGGER_BATCH     – max log entries consumed per LoggerNode tick
# ROVER_LOG_QOS_DEPTH    – ROS publisher queue depth for /rover/logs
# -----------------------------------------------------------------------------
ROVER_LOG_STREAM_KEY=rover:logs
ROVER_LOG_STREAM_MAX=50000
ROVER_LOGGER_DRAIN_HZ=20
ROVER_LOGGER_BLOCK_MS=50
ROVER_LOGGER_BATCH=200
ROVER_LOG_QOS_DEPTH=100

# -----------------------------------------------------------------------------
# Health monitor (IHealthCheckable / HealthMonitorNode)
# ROVER_HEALTH_REGISTRY_KEY – Redis set that tracks all reporting services
# ROVER_HEALTH_TTL_S        – seconds before a health hash expires (stale)
# ROVER_HEALTH_STALE_S      – age (s) at which HealthMonitorNode flags stale
# ROVER_HEALTH_PUBLISH_HZ   – /rover/health publish rate (Hz)
# ROVER_HEALTH_QOS_DEPTH    – ROS publisher queue depth for /rover/health
# -----------------------------------------------------------------------------
ROVER_HEALTH_REGISTRY_KEY=rover:health:__registry__
ROVER_HEALTH_TTL_S=30
ROVER_HEALTH_STALE_S=15
ROVER_HEALTH_PUBLISH_HZ=1
ROVER_HEALTH_QOS_DEPTH=10

# -----------------------------------------------------------------------------
# System health thresholds (SystemHealthService)
# Values that trigger are_you_ok() → False
# -----------------------------------------------------------------------------
ROVER_WARN_CPU_TEMP=75.0
ROVER_CRIT_CPU_TEMP=80.0
ROVER_CRIT_CPU_PCT=95.0
ROVER_CRIT_RAM_PCT=95.0
ROVER_CRIT_DISK_PCT=95.0

# WiFi latency probe
ROVER_PING_COUNT=3

# Bandwidth probe – URL to a small test file (must be HTTP, no redirects)
ROVER_BANDWIDTH_URL=http://speedtest.tele2.net/1MB.zip

# -----------------------------------------------------------------------------
# Mock nodes (MockSensorNode)
# ROVER_MOCK_TICK_HZ – how often each mock sensor ticks (Hz)
# -----------------------------------------------------------------------------
ROVER_MOCK_TICK_HZ=2
